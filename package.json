{
  "name": "react-generative-ui",
  "version": "0.4.1",
  "description": "A plug-and-play React library for rendering AI-generated structured UI components from LLM JSON output.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "require": "./dist/components/*.cjs"
    }
  },
  "bin": {
    "react-generative-ui": "bin/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "templates",
    "bin"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "cd example && npm run dev",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "generative-ui",
    "ai",
    "llm",
    "dynamic-components",
    "openai",
    "groq",
    "component-renderer"
  ],
  "author": "Hema Surya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemasurya106/react-generative-ui.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "recharts": ">=2.10.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "recharts": "^3.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.8"
  }
}
